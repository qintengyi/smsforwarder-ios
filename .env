# 服务器配置
HOST=0.0.0.0
PORT=5001
DEBUG=False
SECRET_KEY=your_strong_secret_key_here

# 登录认证配置
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
AUTH_SECRET=smsf-auth-secret-2024

# SmsForwarder 配置
SMSFORWARDER_IP=192.168.1.16  # 替换为您的手机IP
SMSFORWARDER_PORT=5000
SMSFORWARDER_SECRET=your_secret_key_here  # 与SmsForwarder中设置的密钥一致

# 加密配置（可选）
USE_ENCRYPTION=False
ENCRYPTION_TYPE=SM4